# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=stellarwave_user
DB_PASSWORD=stellarwave_password
DB_NAME=stellarwave

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=24h

# Stellar Network Configuration
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_ISSUER_SECRET_KEY=your_stellar_secret_key_here
STELLAR_ISSUER_PUBLIC_KEY=your_stellar_public_key_here

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Sentry Configuration
SENTRY_DSN=https://your-key@sentry.io/project-id
ENABLE_SENTRY=false

# Storage Configuration (S3/MinIO)
# Set STORAGE_REQUIRED=false to disable storage requirement
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=stellar-cert
STORAGE_REQUIRED=true
