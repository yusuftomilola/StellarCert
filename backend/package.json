    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.15",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
